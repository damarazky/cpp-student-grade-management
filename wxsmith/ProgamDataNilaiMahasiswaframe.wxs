<?xml version="1.0" encoding="utf-8" ?>
<wxsmith>
	<object class="wxFrame" name="ProgamDataNilaiMahasiswaFrame">
		<title>Program Data Nilai Mahasiswa</title>
		<size>950,750</size>
		<bg>wxSYS_COLOUR_MENU</bg>
		<id_arg>0</id_arg>
		<object class="wxStaticText" name="ID_STATICTEXT1" variable="Ib1Judul" member="yes">
			<label>PROGRAM DATA NILAI MAHASISWA</label>
			<pos>256,40</pos>
			<font>
				<size>14</size>
				<style>normal</style>
				<weight>bold</weight>
				<underlined>0</underlined>
				<family>default</family>
				<face>Arial</face>
			</font>
			<style>wxALIGN_CENTRE</style>
		</object>
		<object class="wxStaticText" name="ID_STATICTEXT2" variable="LabelNIM" member="yes">
			<label>NIM</label>
			<pos>56,104</pos>
		</object>
		<object class="wxStaticText" name="ID_STATICTEXT3" variable="LabelNama" member="yes">
			<label>Nama</label>
			<pos>56,144</pos>
		</object>
		<object class="wxStaticText" name="ID_STATICTEXT4" variable="LabelNilaiTugas" member="yes">
			<label>Nilai Tugas</label>
			<pos>56,184</pos>
		</object>
		<object class="wxStaticText" name="ID_STATICTEXT5" variable="LabelNilaiUTS" member="yes">
			<label>Nilai UTS</label>
			<pos>56,224</pos>
		</object>
		<object class="wxStaticText" name="ID_STATICTEXT6" variable="LabelNilaiUAS" member="yes">
			<label>Nilai UAS</label>
			<pos>56,264</pos>
		</object>
		<object class="wxStaticText" name="ID_STATICTEXT7" variable="LabelCariNIMNama" member="yes">
			<label>Cari NIM / Nama</label>
			<pos>56,456</pos>
			<size>113,29</size>
			<style>wxALIGN_CENTRE</style>
		</object>
		<object class="wxTextCtrl" name="ID_TEXTCTRL1" variable="txtNim" member="yes">
			<pos>160,104</pos>
			<size>728,28</size>
		</object>
		<object class="wxTextCtrl" name="ID_TEXTCTRL2" variable="txtNama" member="yes">
			<pos>160,144</pos>
			<size>728,28</size>
		</object>
		<object class="wxTextCtrl" name="ID_TEXTCTRL3" variable="txtTugas" member="yes">
			<pos>160,184</pos>
			<size>728,28</size>
		</object>
		<object class="wxTextCtrl" name="ID_TEXTCTRL4" variable="txtUts" member="yes">
			<pos>160,224</pos>
			<size>728,28</size>
		</object>
		<object class="wxTextCtrl" name="ID_TEXTCTRL5" variable="txtUas" member="yes">
			<pos>160,264</pos>
			<size>728,28</size>
		</object>
		<object class="wxTextCtrl" name="ID_TEXTCTRL6" variable="txtSearch" member="yes">
			<pos>184,456</pos>
			<size>600,28</size>
		</object>
		<object class="wxButton" name="ID_BUTTON1" variable="btnTambah" member="yes">
			<label>Tambah Data</label>
			<pos>56,312</pos>
		</object>
		<object class="wxButton" name="ID_BUTTON2" variable="btnReset" member="yes">
			<label>Reset Tampilan</label>
			<pos>192,312</pos>
		</object>
		<object class="wxButton" name="ID_BUTTON4" variable="btnHapus" member="yes">
			<label>Hapus Data</label>
			<pos>344,312</pos>
			<handler function="OnHapusData" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON5" variable="btnEdit" member="yes">
			<label>Edit Data</label>
			<pos>472,312</pos>
			<handler function="OnEditData" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON6" variable="btnTxt" member="yes">
			<label>Simpan di Txt</label>
			<pos>584,312</pos>
			<handler function="OnSimpanTXT" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON7" variable="btnExcel" member="yes">
			<label>Simpan di Excel</label>
			<pos>720,312</pos>
			<handler function="OnSimpanExcel" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON8" variable="btnAmbil" member="yes">
			<label>Ambil dari File</label>
			<pos>56,360</pos>
			<handler function="OnAmbilFile" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON9" variable="btnLulus" member="yes">
			<label>Cek Lulus</label>
			<pos>192,360</pos>
			<handler function="OnLulus" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON10" variable="btnTidak" member="yes">
			<label>Cek Tidak Lulus</label>
			<pos>304,360</pos>
			<handler function="OnTidakLulus" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON11" variable="btnTertinggi" member="yes">
			<label>Cek Nilai Tertinggi</label>
			<pos>448,360</pos>
			<handler function="OnNilaiTertinggi" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON12" variable="btnTerendah" member="yes">
			<label>Cek Nilai Terendah</label>
			<pos>616,360</pos>
			<handler function="OnNilaiTerendah" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON13" variable="btnRataRata" member="yes">
			<label>Cek Rata - Rata Nilai</label>
			<pos>56,408</pos>
			<handler function="OnNilaiRataRata" entry="EVT_BUTTON" />
		</object>
		<object class="wxButton" name="ID_BUTTON3" variable="btnCari" member="yes">
			<label>Cari</label>
			<pos>792,456</pos>
		</object>
		<object class="wxListCtrl" name="ID_LISTCTRL1" variable="listData" member="yes">
			<pos>56,504</pos>
			<size>832,216</size>
			<style>wxLC_REPORT|wxLC_SINGLE_SEL</style>
		</object>
		<object class="wxMenuBar" variable="MenuBar1" member="no">
			<object class="wxMenu" variable="Menu1" member="no">
				<label>&amp;File</label>
				<object class="wxMenuItem" name="ID_MENUITEM1" variable="MenuItem1" member="no">
					<label>Quit</label>
					<accel>Alt-F4</accel>
					<help>Quit the application</help>
					<handler function="OnQuit" entry="EVT_MENU" />
				</object>
			</object>
			<object class="wxMenu" variable="Menu2" member="no">
				<label>Help</label>
				<object class="wxMenuItem" name="idMenuAbout" variable="MenuItem2" member="no">
					<label>About</label>
					<accel>F1</accel>
					<help>Show info about this application</help>
					<handler function="OnAbout" entry="EVT_MENU" />
				</object>
			</object>
		</object>
		<object class="wxStatusBar" name="ID_STATUSBAR1" variable="StatusBar1" member="yes">
			<fields>1</fields>
			<widths>-1</widths>
			<styles>wxSB_NORMAL</styles>
		</object>
	</object>
</wxsmith>
